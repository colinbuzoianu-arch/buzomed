model AuditLogEntry {
  id              String          @id @default(uuid()) @db.Uuid
  tenantId        String?         @map("tenant_id") @db.Uuid // nullable for super_admin actions
  userId          String?         @map("user_id") @db.Uuid
  
  action          AuditAction
  entityType      String          @map("entity_type")
  entityId        String?         @map("entity_id") @db.Uuid
  entitySummary   String?         @map("entity_summary")
  changes         Json?
  
  ipAddress       String?         @map("ip_address") @db.Inet
  userAgent       String?         @map("user_agent")
  sessionId       String?         @map("session_id")
  
  occurredAt      DateTime        @default(now()) @map("occurred_at") @db.Timestamptz
  
  tenant          Tenant?         @relation(fields: [tenantId], references: [id])
  user            User?           @relation(fields: [userId], references: [id])
  
  @@map("audit_log_entries")
  @@index([tenantId, occurredAt])
  @@index([userId, occurredAt])
  @@index([entityType, entityId, occurredAt])
}

// ============================================================================
// INVITATIONS
// ============================================================================

model Invitation {
  id                  String          @id @default(uuid()) @db.Uuid
  tenantId            String          @map("tenant_id") @db.Uuid

  email               String
  role                UserRole        // role being granted on accept
  locale              String          @default("ro") // language used in invite email

  // Cryptographic token: store SHA-256 hash, never plaintext.
  // The plaintext token is sent in the email URL exactly once.
  tokenHash           String          @unique @map("token_hash")

  expiresAt           DateTime        @map("expires_at") @db.Timestamptz

  invitedByUserId     String          @map("invited_by_user_id") @db.Uuid

  acceptedAt          DateTime?       @map("accepted_at") @db.Timestamptz
  acceptedByUserId    String?         @map("accepted_by_user_id") @db.Uuid

  revokedAt           DateTime?       @map("revoked_at") @db.Timestamptz
  revokedByUserId     String?         @map("revoked_by_user_id") @db.Uuid

  createdAt           DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  tenant              Tenant          @relation(fields: [tenantId], references: [id])
  invitedBy           User            @relation("InvitationInviter", fields: [invitedByUserId], references: [id])
  acceptedBy          User?           @relation("InvitationAcceptor", fields: [acceptedByUserId], references: [id])
  revokedBy           User?           @relation("InvitationRevoker", fields: [revokedByUserId], references: [id])

  @@map("invitations")
  @@index([tenantId])
  @@index([tenantId, email])
  @@index([expiresAt])
  @@index([acceptedAt])
}

// ============================================================================
// SELF-SERVICE REGISTRATIONS
// ============================================================================

model RegisterRequest {
  id          String   @id @default(uuid()) @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  name        String
  email       String
  cabinetName String   @map("cabinet_name")
  city        String?
  status      String   @default("pending")
  tenantId    String?  @map("tenant_id") @db.Uuid

  @@map("register_requests")
  @@index([email])
  @@index([status])
  @@index([createdAt])
}
