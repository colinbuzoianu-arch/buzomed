// ============================================================================
// RECALLS (Friste)
// ============================================================================

model Recall {
  id                          String              @id @default(uuid()) @db.Uuid
  tenantId                    String              @map("tenant_id") @db.Uuid
  employeeId                  String              @map("employee_id") @db.Uuid
  workplaceId                 String              @map("workplace_id") @db.Uuid
  examinationTypeId           String              @map("examination_type_id") @db.Uuid
  
  dueDate                     DateTime            @map("due_date") @db.Date
  
  createdFromExaminationId    String?             @map("created_from_examination_id") @db.Uuid
  completedExaminationId      String?             @map("completed_examination_id") @db.Uuid
  
  status                      RecallStatus        @default(pending)
  
  notificationSentAt          DateTime?           @map("notification_sent_at") @db.Timestamptz
  notificationCount           Int                 @default(0) @map("notification_count")
  
  notes                       String?
  
  createdAt                   DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                   DateTime            @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt                   DateTime?           @map("deleted_at") @db.Timestamptz
  
  tenant                      Tenant              @relation(fields: [tenantId], references: [id])
  employee                    Employee            @relation(fields: [employeeId], references: [id])
  workplace                   Workplace           @relation(fields: [workplaceId], references: [id])
  examinationType             ExaminationType     @relation(fields: [examinationTypeId], references: [id])
  createdFromExamination      Examination?        @relation("RecallSourceExamination", fields: [createdFromExaminationId], references: [id])
  completedExamination        Examination?        @relation("RecallCompletingExamination", fields: [completedExaminationId], references: [id])
  
  @@map("recalls")
  @@index([tenantId])
  @@index([tenantId, dueDate, status])
  @@index([employeeId])
  @@index([status])
}

// ============================================================================
// AUDIT LOG
