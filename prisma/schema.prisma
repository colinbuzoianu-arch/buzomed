// Buzomed v1 — Prisma Schema
// Database: PostgreSQL (Supabase, Frankfurt)
// 
// Conventions:
// - All IDs are UUIDs (gen_random_uuid)
// - All timestamps are timestamptz
// - Soft delete via deletedAt nullable column
// - Multi-tenant: every entity carries tenantId for RLS enforcement
// - JSONB used for structured-but-evolving data (risk profiles, vital signs)
// - Enums defined inline with comments for legal/operational reference

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"] // for Vercel deployment
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // for migrations, bypassing Supabase pooler
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  super_admin
  practice_admin
  practitioner
  assistant
}

enum SubscriptionTier {
  trial
  solo
  practice
  enterprise
}

enum PlanTier {
  starter
  growth
  pro
  enterprise
}

enum SubscriptionStatus {
  trial_active
  trial_expired
  active
  past_due
  canceled
  cancelled  // kept for backward compat (British spelling)
  suspended
  comp
}

enum IdDocumentType {
  cnp
  passport
  eu_id_card
  other
}

enum EmployeeArchivedReason {
  left_employment
  retired
  deceased
  transferred
  other
}

enum WorkAssignmentReason {
  hired
  promoted
  transferred
  role_change
  department_change
  other
}

enum ExaminationStatus {
  scheduled
  in_progress
  completed
  cancelled
  no_show
}

enum ExaminationRequestSource {
  employer_request
  periodic_due
  employee_request
  legal_obligation
  other
}

enum ExaminationVerdict {
  apt
  apt_conditionat
  inapt_temporar
  inapt
}

enum DocumentEntityType {
  examination
  employee
  workplace
  company
  vaccination
  medical_event
}

enum DocumentType {
  fisa_aptitudine
  fisa_factori_risc
  dosarul_medical
  raport_medical
  adeverinta_medicala
  vaccination_certificate
  lab_result
  referral
  external_document
  other
}

enum SignatureMethod {
  digital_image
  qualified_electronic_signature
  physical_print_sign
}

enum TemplateFormat {
  html_handlebars
  docx_template
}

enum AdministrationRoute {
  intramuscular
  subcutaneous
  oral
  intranasal
  other
}

enum MedicalEventType {
  workplace_accident
  sudden_illness
  first_aid
  evacuation
  other
}

enum MedicalEventOutcome {
  fully_recovered
  partially_recovered
  hospitalized
  deceased
  ongoing_treatment
  other
}

enum RecallStatus {
  pending
  scheduled
  completed
  overdue
  cancelled
}

enum ContractStatus {
  draft
  active
  expired
  terminated
}

enum InvoiceStatus {
  draft
  issued
  paid
  overdue
  cancelled
}

enum PlatformInvoiceStatus {
  draft
  issued
  paid
  overdue
  cancelled
}

enum AuditAction {
  create
  read
  update
  delete
  download
  print
  sign
  login
  logout
  export
  import
}

// ============================================================================
// CORE TENANCY
// ============================================================================

model Tenant {
  id                  String              @id @default(uuid()) @db.Uuid
  name                String
  slug                String              @unique
  legalName           String?             @map("legal_name")
  cui                 String?
  registrationNumber  String?             @map("registration_number")
  
  addressLine1        String?             @map("address_line1")
  addressLine2        String?             @map("address_line2")
  city                String?
  county              String?
  postalCode          String?             @map("postal_code")
  country             String              @default("RO")
  
  phone               String?
  email               String?
  website             String?
  
  subscriptionTier    SubscriptionTier    @default(trial) @map("subscription_tier")
  subscriptionStatus  SubscriptionStatus  @default(active) @map("subscription_status")
  trialEndsAt         DateTime?           @map("trial_ends_at") @db.Timestamptz
  
  featureFlags        Json                @default("{}") @map("feature_flags")
  settings            Json                @default("{}")

  cnpHashSalt         String?             @map("cnp_hash_salt")
  logoUrl             String?             @map("logo_url")

  isDemo              Boolean             @default(false) @map("is_demo")

  // GDPR consent tracking
  termsAcceptedAt     DateTime?           @map("terms_accepted_at") @db.Timestamptz
  termsVersion        String?             @map("terms_version")        // e.g. "2026-05"
  privacyAcceptedAt   DateTime?           @map("privacy_accepted_at") @db.Timestamptz
  privacyVersion      String?             @map("privacy_version")
  dpaAcceptedAt       DateTime?           @map("dpa_accepted_at") @db.Timestamptz
  dpaAcceptedBy       String?             @map("dpa_accepted_by")      // full name of person who accepted DPA

  // Data retention (default: 7 years per HG 355/2007)
  dataRetentionYears  Int                 @default(7) @map("data_retention_years")

  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime            @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt           DateTime?           @map("deleted_at") @db.Timestamptz
  
  users               User[]
  invitations         Invitation[]
  locations           Location[]
  companies           Company[]
  contracts           Contract[]
  invoices            Invoice[]
  invoiceItems        InvoiceItem[]
  workplaces          Workplace[]
  employees           Employee[]
  examinations        Examination[]
  documents           Document[]
  documentTemplates   DocumentTemplate[]
  vaccinations        Vaccination[]
  medicalEvents       MedicalEvent[]
  recalls             Recall[]
  auditLogEntries     AuditLogEntry[]
  employeeWorkplaceAssignments EmployeeWorkplaceAssignment[]
  platformInvoices    PlatformInvoice[]
  subscriptions       Subscription[]

  @@map("tenants")
  @@index([slug])
  @@index([deletedAt])
}

model Location {
  id              String          @id @default(uuid()) @db.Uuid
  tenantId        String          @map("tenant_id") @db.Uuid
  name            String
  
  addressLine1    String?         @map("address_line1")
  addressLine2    String?         @map("address_line2")
  city            String?
  county          String?
  postalCode      String?         @map("postal_code")
  
  phone           String?
  email           String?
  
  isPrimary       Boolean         @default(false) @map("is_primary")
  isActive        Boolean         @default(true) @map("is_active")
  
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?       @map("deleted_at") @db.Timestamptz
  
  tenant                  Tenant                    @relation(fields: [tenantId], references: [id])
  examinations            Examination[]
  userLocationAssignments UserLocationAssignment[]
  
  @@map("locations")
  @@index([tenantId])
  @@index([tenantId, isPrimary])
}

// ============================================================================
// USERS & AUTH
// ============================================================================

model User {
  id                  String                   @id @default(uuid()) @db.Uuid
  tenantId            String?                  @map("tenant_id") @db.Uuid // null for super_admin
  email               String                   @unique
  authUserId          String?                  @unique @map("auth_user_id") @db.Uuid // links to supabase auth.users
  
  firstName           String                   @map("first_name")
  lastName            String                   @map("last_name")
  phone               String?
  
  roles               UserRole[]               // multi-role support per question 1
  
  professionalTitle   String?                  @map("professional_title")
  specialty           String?                  // e.g. "Medic primar medicina muncii"
  professionalCode    String?                  @map("professional_code") // parafa code
  cnpEncrypted        String?                  @map("cnp_encrypted") // for practitioners; encrypted via pgcrypto
  cnpHash             String?                  @map("cnp_hash") // for lookup
  
  signatureImageUrl   String?                  @map("signature_image_url")
  stampImageUrl       String?                  @map("stamp_image_url")
  
  isActive            Boolean                  @default(true) @map("is_active")
  lastLoginAt         DateTime?                @map("last_login_at") @db.Timestamptz

  // GDPR consent for practitioners
  termsAcceptedAt     DateTime?                @map("terms_accepted_at") @db.Timestamptz
  termsVersion        String?                  @map("terms_version")

  createdAt           DateTime                 @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime                 @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt           DateTime?                @map("deleted_at") @db.Timestamptz
  
  tenant                          Tenant?                       @relation(fields: [tenantId], references: [id])
  userLocationAssignments         UserLocationAssignment[]
  
  examinationsAsPractitioner      Examination[]                 @relation("ExaminationPractitioner")
  examinationsSigned              Examination[]                 @relation("ExaminationSigner")
  vaccinationsAdministered        Vaccination[]
  medicalEventsHandled            MedicalEvent[]
  workplacesCreated               Workplace[]
  employeesCreated                Employee[]
  documentsUploaded               Document[]                    @relation("DocumentUploader")
  documentsSigned                 Document[]                    @relation("DocumentSigner")
  auditLogEntries                 AuditLogEntry[]
  invitationsCreated      Invitation[]                  @relation("InvitationInviter")
  invitationsAccepted     Invitation[]                  @relation("InvitationAcceptor")
  invitationsRevoked      Invitation[]                  @relation("InvitationRevoker")
  
  @@map("users")
  @@index([tenantId])
  @@index([email])
  @@index([authUserId])
}

model UserLocationAssignment {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  locationId  String   @map("location_id") @db.Uuid
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  
  user        User      @relation(fields: [userId], references: [id])
  location    Location  @relation(fields: [locationId], references: [id])
  
  @@map("user_location_assignments")
  @@unique([userId, locationId])
  @@index([userId])
  @@index([locationId])
}

// ============================================================================
// COMPANIES & WORKPLACES
// ============================================================================

model Company {
  id                  String      @id @default(uuid()) @db.Uuid
  tenantId            String      @map("tenant_id") @db.Uuid
  
  name                String
  cui                 String?
  registrationNumber  String?     @map("registration_number")
  caenCode            String?     @map("caen_code")
  
  addressLine1        String?     @map("address_line1")
  addressLine2        String?     @map("address_line2")
  city                String?
  county              String?
  postalCode          String?     @map("postal_code")
  
  phone               String?
  email               String?
  website             String?
  
  contactPersonName   String?     @map("contact_person_name")
  contactPersonRole   String?     @map("contact_person_role")
  contactPersonPhone  String?     @map("contact_person_phone")
  contactPersonEmail  String?     @map("contact_person_email")
  
  contractStartDate   DateTime?   @map("contract_start_date") @db.Date
  contractEndDate     DateTime?   @map("contract_end_date") @db.Date
  
  notes                       String?
  recallNotificationEmail     String?  @map("recall_notification_email")
  isActive            Boolean     @default(true) @map("is_active")

  createdAt           DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime    @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt           DateTime?   @map("deleted_at") @db.Timestamptz

  tenant              Tenant          @relation(fields: [tenantId], references: [id])
  workplaces          Workplace[]
  contracts           Contract[]
  invoices            Invoice[]
  medicalEvents       MedicalEvent[]
  employees           Employee[]      @relation("EmployeeCompany")

  @@map("companies")
  @@index([tenantId])
  @@index([tenantId, name])
  @@index([cui])
}

model Contract {
  id                  String          @id @default(uuid()) @db.Uuid
  tenantId            String          @map("tenant_id") @db.Uuid
  companyId           String          @map("company_id") @db.Uuid

  contractNumber      String          @map("contract_number")
  contractYear        Int             @map("contract_year")
  contractSequence    Int             @map("contract_sequence")

  startDate           DateTime        @map("start_date") @db.Date
  endDate             DateTime?       @map("end_date") @db.Date

  services            Json            @default("[]")

  pricePerExamination Decimal?        @map("price_per_examination") @db.Decimal(10, 2)
  priceMonthlyFlat    Decimal?        @map("price_monthly_flat") @db.Decimal(10, 2)
  currency            String          @default("RON")

  status              ContractStatus  @default(draft)
  notes               String?

  createdAt           DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt           DateTime?       @map("deleted_at") @db.Timestamptz

  tenant              Tenant          @relation(fields: [tenantId], references: [id])
  company             Company         @relation(fields: [companyId], references: [id])
  invoices            Invoice[]

  @@map("contracts")
  @@unique([tenantId, contractYear, contractSequence])
  @@index([tenantId])
  @@index([companyId])
  @@index([tenantId, status])
  @@index([deletedAt])
}

model Invoice {
  id                String        @id @default(uuid()) @db.Uuid
  tenantId          String        @map("tenant_id") @db.Uuid
  companyId         String        @map("company_id") @db.Uuid
  contractId        String?       @map("contract_id") @db.Uuid

  invoiceNumber     String        @map("invoice_number")
  invoiceYear       Int           @map("invoice_year")
  invoiceSequence   Int           @map("invoice_sequence")

  status            InvoiceStatus @default(draft)
  issuedAt          DateTime?     @map("issued_at") @db.Timestamptz
  dueDate           DateTime?     @map("due_date") @db.Date
  paidAt            DateTime?     @map("paid_at") @db.Timestamptz

  subtotal          Decimal       @db.Decimal(12, 2)
  vatRate           Decimal       @default(0) @map("vat_rate") @db.Decimal(5, 4)
  vatAmount         Decimal       @default(0) @map("vat_amount") @db.Decimal(12, 2)
  total             Decimal       @db.Decimal(12, 2)
  currency          String        @default("RON")

  vatExemptReason   String?       @map("vat_exempt_reason")
  notes             String?

  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime?     @map("deleted_at") @db.Timestamptz

  tenant            Tenant        @relation(fields: [tenantId], references: [id])
  company           Company       @relation(fields: [companyId], references: [id])
  contract          Contract?     @relation(fields: [contractId], references: [id])
  items             InvoiceItem[]

  @@map("invoices")
  @@unique([tenantId, invoiceYear, invoiceSequence])
  @@index([tenantId])
  @@index([companyId])
  @@index([tenantId, status])
  @@index([deletedAt])
}

model InvoiceItem {
  id            String   @id @default(uuid()) @db.Uuid
  invoiceId     String   @map("invoice_id") @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid

  description   String
  quantity      Decimal  @db.Decimal(10, 2)
  unitPrice     Decimal  @map("unit_price") @db.Decimal(12, 2)
  lineTotal     Decimal  @map("line_total") @db.Decimal(12, 2)

  sortOrder     Int      @default(0) @map("sort_order")

  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  @@map("invoice_items")
  @@index([invoiceId])
  @@index([tenantId])
}

model PlatformInvoice {
  id                    String                @id @default(uuid()) @db.Uuid
  tenantId              String                @map("tenant_id") @db.Uuid
  invoiceNumber         String                @map("invoice_number")
  invoiceYear           Int                   @map("invoice_year")
  invoiceSequence       Int                   @map("invoice_sequence")
  status                PlatformInvoiceStatus @default(draft)
  issuedAt              DateTime?             @map("issued_at") @db.Timestamptz
  dueDate               DateTime?             @map("due_date") @db.Date
  paidAt                DateTime?             @map("paid_at") @db.Timestamptz
  subtotal              Decimal               @db.Decimal(12, 2)
  vatRate               Decimal               @default(0) @map("vat_rate") @db.Decimal(5, 4)
  vatAmount             Decimal               @default(0) @map("vat_amount") @db.Decimal(12, 2)
  total                 Decimal               @db.Decimal(12, 2)
  currency              String                @default("RON")
  vatExemptReason       String?               @map("vat_exempt_reason")
  notes                 String?
  snapshotTenantName    String?               @map("snapshot_tenant_name")
  snapshotTenantCui     String?               @map("snapshot_tenant_cui")
  snapshotTenantAddress String?               @map("snapshot_tenant_address")
  snapshotTenantEmail   String?               @map("snapshot_tenant_email")
  createdAt             DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime              @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt             DateTime?             @map("deleted_at") @db.Timestamptz
  tenant                Tenant                @relation(fields: [tenantId], references: [id])
  items                 PlatformInvoiceItem[]

  @@map("platform_invoices")
  @@unique([invoiceYear, invoiceSequence])
  @@index([tenantId])
  @@index([status])
  @@index([deletedAt])
}

model PlatformInvoiceItem {
  id          String          @id @default(uuid()) @db.Uuid
  invoiceId   String          @map("invoice_id") @db.Uuid
  description String
  quantity    Decimal         @db.Decimal(10, 2)
  unitPrice   Decimal         @map("unit_price") @db.Decimal(12, 2)
  lineTotal   Decimal         @map("line_total") @db.Decimal(12, 2)
  sortOrder   Int             @default(0) @map("sort_order")
  invoice     PlatformInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("platform_invoice_items")
  @@index([invoiceId])
}

// ============================================================================
// SUBSCRIPTION MANAGEMENT
// ============================================================================

model Plan {
  id               String        @id @default(cuid())
  name             String
  tier             PlanTier      @unique
  monthlyPrice     Decimal       @map("monthly_price") @db.Decimal(10, 2)
  maxEmployees     Int           @map("max_employees")  // -1 = unlimited
  isPublic         Boolean       @default(true) @map("is_public")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  subscriptions    Subscription[]

  @@map("plans")
}

model Subscription {
  id                   String             @id @default(cuid())
  tenantId             String             @map("tenant_id") @db.Uuid
  planId               String?            @map("plan_id")
  tier                 PlanTier           @default(starter)
  status               SubscriptionStatus @default(trial_active)
  trialEndsAt          DateTime?          @map("trial_ends_at") @db.Timestamptz
  currentPeriodStart   DateTime?          @map("current_period_start") @db.Timestamptz
  currentPeriodEnd     DateTime?          @map("current_period_end") @db.Timestamptz
  canceledAt           DateTime?          @map("canceled_at") @db.Timestamptz
  stripeCustomerId     String?            @map("stripe_customer_id")
  stripeSubscriptionId String?            @map("stripe_subscription_id")
  notes                String?
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  tenant               Tenant             @relation(fields: [tenantId], references: [id])
  plan                 Plan?              @relation(fields: [planId], references: [id])

  @@map("subscriptions")
  @@index([tenantId])
  @@index([status])
}

model Workplace {
  id                          String      @id @default(uuid()) @db.Uuid
  tenantId                    String      @map("tenant_id") @db.Uuid
  companyId                   String      @map("company_id") @db.Uuid
  
  name                        String
  department                  String?
  description                 String?
  
  // Risk profile mirrors fișa de identificare a factorilor de risc
  // Stored as JSONB for schema flexibility — legal form may evolve
  riskProfile                 Json        @default("{}") @map("risk_profile")
  
  // Examination requirements driven by hazard profile
  requiredExaminationTypeIds  String[]    @map("required_examination_type_ids") @db.Uuid
  examinationIntervalMonths   Int         @default(12) @map("examination_interval_months")
  
  riskAssessmentSignedByCompany Boolean   @default(false) @map("risk_assessment_signed_by_company")
  riskAssessmentSignedAt        DateTime? @map("risk_assessment_signed_at") @db.Date
  
  isActive                    Boolean     @default(true) @map("is_active")
  
  createdByUserId             String?     @map("created_by_user_id") @db.Uuid
  createdAt                   DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                   DateTime    @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt                   DateTime?   @map("deleted_at") @db.Timestamptz
  
  tenant                      Tenant                          @relation(fields: [tenantId], references: [id])
  company                     Company                         @relation(fields: [companyId], references: [id])
  createdBy                   User?                           @relation(fields: [createdByUserId], references: [id])
  employeeAssignments         EmployeeWorkplaceAssignment[]
  examinations                Examination[]
  recalls                     Recall[]
  
  @@map("workplaces")
  @@index([tenantId])
  @@index([companyId])
}

// ============================================================================
// EMPLOYEES
// ============================================================================

model Employee {
  id                          String                @id @default(uuid()) @db.Uuid
  tenantId                    String                @map("tenant_id") @db.Uuid
  
  // Legal identification
  cnpEncrypted                String?               @map("cnp_encrypted") // pgcrypto-encrypted
  cnpHash                     String?               @map("cnp_hash") // tenant-salted hash for lookup
  idDocumentType              IdDocumentType        @default(cnp) @map("id_document_type")
  idDocumentNumber            String?               @map("id_document_number") // for non-CNP cases
  
  // Operational identification (per question 4 — Interpretation A)
  companyEmployeeId           String?               @map("company_employee_id") // badge / matricola
  jobTitle                    String?               @map("job_title")
  companyId                   String?               @map("company_id") @db.Uuid

  // Personal data
  lastName                    String                @map("last_name")
  firstName                   String                @map("first_name")
  birthDate                   DateTime?             @map("birth_date") @db.Date
  gender                      String?               // 'M' | 'F' | other
  nationality                 String                @default("RO")
  
  addressLine1                String?               @map("address_line1")
  addressLine2                String?               @map("address_line2")
  city                        String?
  county                      String?
  postalCode                  String?               @map("postal_code")
  
  phone                       String?
  email                       String?
  
  emergencyContactName         String?              @map("emergency_contact_name")
  emergencyContactPhone        String?              @map("emergency_contact_phone")
  emergencyContactRelationship String?              @map("emergency_contact_relationship")
  
  // Medical summary (the "always visible" stuff)
  medicalHistorySummary       String?               @map("medical_history_summary")
  chronicConditions           Json                  @default("[]") @map("chronic_conditions")
  chronicMedications          Json                  @default("[]") @map("chronic_medications")
  allergies                   Json                  @default("[]") // the "Cave" field — flagged in UI
  vaccinationsSummary         String?               @map("vaccinations_summary")
  bloodType                   String?               @map("blood_type")
  
  notes                       String?
  
  isActive                    Boolean               @default(true) @map("is_active")
  archivedAt                  DateTime?             @map("archived_at") @db.Timestamptz

  // Per-employee retention override — for workers with special legal exposure
  // (asbestos, radiation, etc. — up to 40 years by law)
  // null = use tenant default; non-null = override
  dataRetentionYears          Int?                  @map("data_retention_years")
  archivedReason              EmployeeArchivedReason? @map("archived_reason")
  
  createdByUserId             String?               @map("created_by_user_id") @db.Uuid
  createdAt                   DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                   DateTime              @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt                   DateTime?             @map("deleted_at") @db.Timestamptz
  
  tenant                      Tenant                          @relation(fields: [tenantId], references: [id])
  company                     Company?                        @relation("EmployeeCompany", fields: [companyId], references: [id])
  createdBy                   User?                           @relation(fields: [createdByUserId], references: [id])
  workplaceAssignments        EmployeeWorkplaceAssignment[]
  examinations                Examination[]
  vaccinations                Vaccination[]
  medicalEvents               MedicalEvent[]
  recalls                     Recall[]

  @@map("employees")
  @@index([tenantId])
  @@index([tenantId, cnpHash])
  @@index([tenantId, lastName, firstName])
  @@index([tenantId, companyEmployeeId])
  @@index([tenantId, archivedAt])
  @@index([archivedAt])
  @@index([companyId])
}

model EmployeeWorkplaceAssignment {
  id                  String                @id @default(uuid()) @db.Uuid
  tenantId            String                @map("tenant_id") @db.Uuid
  employeeId          String                @map("employee_id") @db.Uuid
  workplaceId         String                @map("workplace_id") @db.Uuid
  
  startDate           DateTime              @map("start_date") @db.Date
  endDate             DateTime?             @map("end_date") @db.Date
  isCurrent           Boolean               @default(true) @map("is_current")
  
  reasonForChange     WorkAssignmentReason? @map("reason_for_change")
  notes               String?
  
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime              @updatedAt @map("updated_at") @db.Timestamptz
  
  tenant              Tenant      @relation(fields: [tenantId], references: [id])
  employee            Employee    @relation(fields: [employeeId], references: [id])
  workplace           Workplace   @relation(fields: [workplaceId], references: [id])
  
  @@map("employee_workplace_assignments")
  @@index([tenantId])
  @@index([employeeId, isCurrent])
  @@index([workplaceId])
}

// ============================================================================
// EXAMINATIONS
// ============================================================================

model ExaminationType {
  id                      String          @id @default(uuid()) @db.Uuid
  code                    String          @unique // 'angajare', 'control_periodic', etc.
  nameRo                  String          @map("name_ro")
  nameDe                  String?         @map("name_de") // for future i18n
  nameEn                  String?         @map("name_en")
  description             String?
  legalReference          String?         @map("legal_reference") // 'HG 355/2007 art. X'
  defaultValidityMonths   Int             @default(12) @map("default_validity_months")
  isActive                Boolean         @default(true) @map("is_active")
  isSystem                Boolean         @default(true) @map("is_system")
  
  createdAt               DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  
  examinations            Examination[]
  recalls                 Recall[]
  
  @@map("examination_types")
}

model Examination {
  id                          String                    @id @default(uuid()) @db.Uuid
  tenantId                    String                    @map("tenant_id") @db.Uuid
  
  employeeId                  String                    @map("employee_id") @db.Uuid
  workplaceId                 String                    @map("workplace_id") @db.Uuid // snapshot at exam time
  examinationTypeId           String                    @map("examination_type_id") @db.Uuid
  practitionerId              String                    @map("practitioner_id") @db.Uuid
  locationId                  String                    @map("location_id") @db.Uuid
  
  // Per question 3: per tenant per year numbering
  examinationNumber           String                    @map("examination_number") // '2025/0001'
  examinationYear             Int                       @map("examination_year")
  examinationSequence         Int                       @map("examination_sequence")
  
  scheduledAt                 DateTime?                 @map("scheduled_at") @db.Timestamptz
  startedAt                   DateTime?                 @map("started_at") @db.Timestamptz
  completedAt                 DateTime?                 @map("completed_at") @db.Timestamptz
  
  status                      ExaminationStatus         @default(scheduled)
  requestSource               ExaminationRequestSource? @map("request_source")
  referringDocumentNumber     String?                   @map("referring_document_number")
  
  // Clinical data
  anamnesis                   Json                      @default("{}") // structured Q&A
  vitalSigns                  Json                      @default("{}") @map("vital_signs")
  visionTest                  Json                      @default("{}") @map("vision_test")
  hearingTest                 Json                      @default("{}") @map("hearing_test")
  lungFunction                Json                      @default("{}") @map("lung_function")
  additionalTests             Json                      @default("{}") @map("additional_tests")
  maternityRisk               Json                      @default("{}") @map("maternity_risk")

  clinicalFindings            String?                   @map("clinical_findings")
  diagnoses                   Json                      @default("[]")
  recommendations             String?
  
  // Verdict (matches fișa de aptitudine)
  verdict                     ExaminationVerdict?
  verdictConditions           String?                   @map("verdict_conditions")
  inaptTemporarUntil          DateTime?                 @map("inapt_temporar_until") @db.Date
  
  // Recall calculation
  nextExaminationDueDate      DateTime?                 @map("next_examination_due_date") @db.Date
  
  // Internal practitioner notes (not on official documents)
  notes                       String?
  
  // Immutability after signing
  signedAt                    DateTime?                 @map("signed_at") @db.Timestamptz
  signedByUserId              String?                   @map("signed_by_user_id") @db.Uuid
  
  createdAt                   DateTime                  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                   DateTime                  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt                   DateTime?                 @map("deleted_at") @db.Timestamptz
  
  tenant                      Tenant              @relation(fields: [tenantId], references: [id])
  employee                    Employee            @relation(fields: [employeeId], references: [id])
  workplace                   Workplace           @relation(fields: [workplaceId], references: [id])
  examinationType             ExaminationType     @relation(fields: [examinationTypeId], references: [id])
  practitioner                User                @relation("ExaminationPractitioner", fields: [practitionerId], references: [id])
  location                    Location            @relation(fields: [locationId], references: [id])
  signedBy                    User?               @relation("ExaminationSigner", fields: [signedByUserId], references: [id])
  
  vaccinations                Vaccination[]
  recallsTriggered            Recall[]            @relation("RecallSourceExamination")
  recallsCompleted            Recall[]            @relation("RecallCompletingExamination")
  
  @@map("examinations")
  @@unique([tenantId, examinationYear, examinationSequence])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, completedAt])
  @@index([employeeId, completedAt])
  @@index([practitionerId, completedAt])
  @@index([status])
}

// ============================================================================
// DOCUMENTS
// ============================================================================

model Document {
  id                          String              @id @default(uuid()) @db.Uuid
  tenantId                    String              @map("tenant_id") @db.Uuid
  
  // Polymorphic ownership
  entityType                  DocumentEntityType  @map("entity_type")
  entityId                    String              @map("entity_id") @db.Uuid
  
  documentType                DocumentType        @map("document_type")
  filename                    String
  storagePath                 String              @map("storage_path") // Supabase Storage path
  mimeType                    String              @map("mime_type")
  fileSizeBytes               BigInt              @map("file_size_bytes")
  
  isGenerated                 Boolean             @default(false) @map("is_generated")
  generatedFromTemplateId     String?             @map("generated_from_template_id") @db.Uuid
  generatedDataSnapshot       Json?               @map("generated_data_snapshot")
  
  documentNumber              String?             @map("document_number")
  documentYear                Int?                @map("document_year")
  documentSequence            Int?                @map("document_sequence")
  
  issuedAt                    DateTime?           @map("issued_at") @db.Timestamptz
  signedByUserId              String?             @map("signed_by_user_id") @db.Uuid
  signatureMethod             SignatureMethod?    @map("signature_method")
  
  isOfficial                  Boolean             @default(false) @map("is_official")
  version                     Int                 @default(1)
  replacesDocumentId          String?             @map("replaces_document_id") @db.Uuid
  
  uploadedByUserId            String?             @map("uploaded_by_user_id") @db.Uuid
  
  createdAt                   DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                   DateTime            @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt                   DateTime?           @map("deleted_at") @db.Timestamptz
  
  tenant                      Tenant              @relation(fields: [tenantId], references: [id])
  template                    DocumentTemplate?   @relation(fields: [generatedFromTemplateId], references: [id])
  signedBy                    User?               @relation("DocumentSigner", fields: [signedByUserId], references: [id])
  uploadedBy                  User?               @relation("DocumentUploader", fields: [uploadedByUserId], references: [id])
  replacesDocument            Document?           @relation("DocumentVersions", fields: [replacesDocumentId], references: [id])
  replacedByDocuments         Document[]          @relation("DocumentVersions")
  
  @@map("documents")
  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, documentType])
  @@index([tenantId, documentYear, documentSequence])
}

model DocumentTemplate {
  id                  String          @id @default(uuid()) @db.Uuid
  tenantId            String?         @map("tenant_id") @db.Uuid // null = system template
  
  code                String
  name                String
  documentType        DocumentType    @map("document_type")
  version             Int             @default(1)
  templateFormat      TemplateFormat  @default(html_handlebars) @map("template_format")
  templateContent     String          @map("template_content")
  fieldMappings       Json            @default("{}") @map("field_mappings")
  
  isActive            Boolean         @default(true) @map("is_active")
  isSystem            Boolean         @default(false) @map("is_system")
  
  createdAt           DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  
  tenant              Tenant?         @relation(fields: [tenantId], references: [id])
  documents           Document[]
  
  @@map("document_templates")
  @@unique([tenantId, code, version])
  @@index([tenantId])
}

